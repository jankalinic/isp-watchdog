[Unit]
Description=netwatch background collector (ping/traceroute/speedtest)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/pi/netwatch
ExecStart=/usr/bin/python3 /home/pi/netwatch/netwatch.py
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
